{
  "name": "bazi-ziwei-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "copy-calc-deps": "node -e \"const{cpSync}=require('fs');const{join}=require('path');const s=join('node_modules','lunar-typescript');const d=join('calculator','node_modules','lunar-typescript');cpSync(s,d,{recursive:true});console.log('copied lunar-typescript to calculator/node_modules')\"",
    "prebuild": "npm run copy-calc-deps",
    "build": "npm run copy-calc-deps && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "lunar-typescript": "^1.8.6",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
